  "narrative": {
    "northStar": "The Host-Native Console",
    "overview": "Nova Command Center is an Operate-mode tool that lives inside Laravel Nova. Visual authority comes from matching the host admin — Nova’s light/dark switch, primary accent, density — while package-owned CSS keeps every surface readable when the host’s purged Tailwind build omits utilities. Craft shows up in precise details (focus rings, confirm-safe modal focus, status accents that mean something) rather than a separate product brand shell.",
    "keyCharacteristics": [
      "Host-native: inherit Nova --primary; follow .dark on <html>",
      "Meaning-first color: only danger/warning diverge from primary on Run controls",
      "Purge-safe: colors, icons, fractional sizes live in package CSS, not host utilities",
      "Dense admin layout with 44px minimum touch targets on interactive chrome"
    ],
    "rules": [
      {
        "name": "The Meaning Accent Rule",
        "body": "Only danger and warning command types get non-primary Run/stripe colors. Other types share Nova primary — decorative rainbow accents are noise.",
        "section": "colors"
      },
      {
        "name": "The Purge-Safe Rule",
        "body": "Never rely on host Tailwind color utilities for tool chrome. Put colors in tool.css (with .dark twins).",
        "section": "colors"
      }
    ],
    "dos": [
      "Follow Nova .dark and --primary",
      "Keep danger/warning as the only semantic Run accents",
      "Prefer package CSS for colors, icons, and fractional sizes",
      "Preserve keyboard paths (modal trap, history keys, combobox arrows)",
      "Respect prefers-reduced-motion"
    ],
    "donts": [
      "Invent a marketing brand UI that fights Nova chrome",
      "Rainbow-color every command type",
      "Hide critical actions behind hover-only on touch",
      "Depend on host Tailwind purge for contrast or icon size",
      "Soft-pedal risk copy in confirmations or notices"
    ]
  }
